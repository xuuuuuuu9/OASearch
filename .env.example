# Required for CrossRef polite pool and Unpaywall API
USER_EMAIL=you@example.com

# Storage paths. Leave blank/default to use ./data/library.db and ./data/pdfs.
# For a large private library, put PDF_DIR on a large disk folder.
# DATA_DIR=D:/np-oa-library
# PDF_DIR=D:/np-oa-library/pdfs
# DB_PATH=D:/np-oa-library/library.db

# Global concurrent PDF downloads (1-32). Good private-use range: 12-16.
# The downloader also applies per-host limits and backoff.
DOWNLOAD_CONCURRENCY=16

# Safer mode: caps global downloads at 4 and staggers starts by 200ms.
# Use when you see many 403/429/503 responses.
POLITE_MODE=false

# Concurrent Unpaywall lookups during a search
OA_LOOKUP_CONCURRENCY=20

# Sci-Hub fallback for non-OA papers (default enabled).
# Set to false to disable. Sci-hub is added as the lowest-priority
# candidate source, only used when no OA candidate exists.
# ENABLE_SCIHUB=true
# Optional comma-separated override of mirror list (default = 6 built-in).
# SCIHUB_MIRRORS=https://sci-hub.se,https://sci-hub.ru

# 服务端口（可选，默认 8000 / 3000）
# NP_OA_BACKEND_PORT=8000
# NP_OA_FRONTEND_PORT=3000
